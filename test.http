### 1. GET - Raíz
GET http://127.0.0.1:8000/ HTTP/1.1

### 2. GET - Health Check
# GET http://127.0.0.1:8000/health HTTP/1.1

### ============ AUTORES ============
### 3. GET - Todos los autores
GET http://127.0.0.1:8000/api/v1/autores_all HTTP/1.1

### 4. GET - Autor por ID
GET http://127.0.0.1:8000/api/v1/autores/1 HTTP/1.1

### 5. POST - Crear autor
POST http://127.0.0.1:8000/api/v1/autores HTTP/1.1
Content-Type: application/json

{
    "nombre": "Gabriel",
    "apellido": "García Márquez",
    "nacionalidad": "Colombiana",
    "fecha_nacimiento": "1927-03-06",
    "biografia": "Premio Nobel de Literatura 1982"
}

### 6. PUT - Actualizar autor
PUT http://127.0.0.1:8000/api/v1/autores/1 HTTP/1.1
Content-Type: application/json

{
    "nombre": "Gabriel José",
    "apellido": "García Márquez",
    "nacionalidad": "Colombiana",
    "fecha_nacimiento": "1927-03-06",
    "biografia": "Escritor colombiano, premio Nobel 1982"
}

### 7. DELETE - Eliminar autor
DELETE http://127.0.0.1:8000/api/v1/autores/11 HTTP/1.1

### ============ EDITORIALES ============
### 8. GET - Todas las editoriales
GET http://127.0.0.1:8000/api/v1/editoriales HTTP/1.1

### 9. POST - Crear editorial
POST http://127.0.0.1:8000/api/v1/editoriales HTTP/1.1
Content-Type: application/json

{
    "nombre": "Editorial Planeta",
    "direccion": "Barcelona, España",
    "email": "info@planeta.com",
    "sitio_web": "www.planeta.com"
}

### ============ CATEGORIAS ============
### 10. GET - Todas las categorías
GET http://127.0.0.1:8000/api/v1/categorias HTTP/1.1

### 11. POST - Crear categoría
POST http://127.0.0.1:8000/api/v1/categorias HTTP/1.1
Content-Type: application/json

{
    "nombre": "Ciencia Ficción",
    "descripcion": "Libros de ficción con base científica",
    "categoria_padre_id": 1
}

### ============ LIBROS ============
### 12. GET - Todos los libros
GET http://127.0.0.1:8000/api/v1/libros HTTP/1.1

### 13. GET - Libros con detalle
GET http://127.0.0.1:8000/api/v1/libros/detalle HTTP/1.1

### 14. GET - Libro por ID
GET http://127.0.0.1:8000/api/v1/libros/1 HTTP/1.1

### 15. GET - Libro por ID con detalle
GET http://127.0.0.1:8000/api/v1/libros/1/detalle HTTP/1.1

### 16. POST - Crear libro
POST http://127.0.0.1:8000/api/v1/libros HTTP/1.1
Content-Type: application/json

{
    "isbn": "978-84-376-0494-7",
    "titulo": "Cien años de soledad",
    "editorial_id": 1,
    "anio_publicacion": 1967,
    "numero_paginas": 496,
    "idioma": "Español",
    "ejemplares_totales": 5,
    "ejemplares_disponibles": 5,
    "autor_ids": [1],
    "categoria_ids": [1, 3]
}

### 17. PUT - Actualizar libro
PUT http://127.0.0.1:8000/api/v1/libros/1 HTTP/1.1
Content-Type: application/json

{
    "isbn": "978-84-376-0494-7",
    "titulo": "Cien años de soledad (Edición especial)",
    "editorial_id": 1,
    "anio_publicacion": 1967,
    "numero_paginas": 500,
    "idioma": "Español",
    "ejemplares_totales": 5,
    "ejemplares_disponibles": 3,
    "autor_ids": [1],
    "categoria_ids": [1, 3]
}

### 18. DELETE - Eliminar libro
DELETE http://127.0.0.1:8000/api/v1/libros/9 HTTP/1.1

### ============ USUARIOS ============
### 19. GET - Todos los usuarios
GET http://127.0.0.1:8000/api/v1/usuarios HTTP/1.1

### 20. POST - Crear usuario
POST http://127.0.0.1:8000/api/v1/usuarios HTTP/1.1
Content-Type: application/json

{
    "tipo_documento": "DNI",
    "numero_documento": "12345678A",
    "nombre": "Juan",
    "apellido": "Pérez",
    "email": "juan.perez@email.com",
    "telefono": "600111222",
    "tipo_usuario": "ESTUDIANTE"
}

